---
const currentPath = Astro.url.pathname;
const base = '/GoswickRanchMayerArizona';

function isActive(href: string): boolean {
  const hrefNorm = href.replace(/\/$/, '');
  const pathNorm = currentPath.replace(/\/$/, '');
  // Home: exact match only
  if (hrefNorm === base || hrefNorm === '') {
    return pathNorm === base || pathNorm === '';
  }
  // Section links: match prefix, but only if longer than base
  return hrefNorm.length > base.length && pathNorm.startsWith(hrefNorm);
}

const navLinks = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/about/`, label: 'About' },
  { href: `${base}/lifestyle/`, label: 'Life Here' },
  { href: `${base}/hoa/`, label: 'HOA Info' },
  { href: `${base}/buyers/`, label: 'For Buyers', class: 'nav-buyers' },
  { href: `${base}/resources/`, label: 'Resources' },
  { href: `${base}/contact/`, label: 'Contact' },
];
---

<header class="site-header">
  <div class="container">
    <a href={`${base}/`} class="site-logo">Goswick Ranch HOA</a>
    <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <nav class="site-nav" aria-label="Main navigation">
      <ul>
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[link.class, { active: isActive(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement | null;
  const nav = document.querySelector('.site-nav') as HTMLElement | null;

  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    nav.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        nav.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });

    document.addEventListener('click', (e: MouseEvent) => {
      if (!nav.contains(e.target as Node) && !toggle.contains(e.target as Node)) {
        nav.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>
