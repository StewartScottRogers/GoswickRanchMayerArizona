---
import PageLayout from '../../layouts/PageLayout.astro';

const base = '/GoswickRanchMayerArizona';
---

<PageLayout
  title="Photo Gallery — Goswick Ranch HOA"
  description="Photos of Goswick Ranch — community entrance, mountain views, four seasons, Big Bug Creek, aerial overview, and subdivision plat. Mayer, Arizona."
  pageTitle="Community Gallery"
  pageSubtitle="Photos of Goswick Ranch — gate, mountain views, four seasons, Big Bug Creek, and the surrounding Bradshaw Mountains."
  breadcrumbs={[
    { label: 'Home', href: `${base}/` },
    { label: 'About', href: `${base}/about/` },
    { label: 'Gallery' }
  ]}
>
  <div class="page-content">

    <!-- Community Entrance -->
    <h2 class="gallery-section-title">Community Entrance</h2>
    <div class="photo-grid">
      <div class="photo-item wide">
        <figure>
          <img src={`${base}/img/1062124_P23.jpg`}
               alt="Goswick Ranch ornamental iron gate with full-height cowboy and cowgirl silhouettes flanking a central sun design — the community entrance off Poland Road"
               loading="eager">
          <figcaption>
            <strong>The Goswick Ranch Gate</strong>
            Custom ornamental iron gate with cowboy and cowgirl silhouette panels flanking a sun design —
            the community entrance off Poland Road. The lockbox access system allows residents to manage
            entry for guests and vendors.
          </figcaption>
        </figure>
      </div>
    </div>

    <!-- Ranch Views -->
    <h2 class="gallery-section-title">Ranch Views</h2>
    <div class="photo-grid">

      <div class="photo-item wide">
        <figure>
          <img src={`${base}/img/hero-panorama.png`}
               alt="View from 2 S Hawk Mountain Trail, Goswick Ranch — open sky, native scrub, and Bradshaw Mountain foothills stretching to the horizon"
               loading="lazy">
          <figcaption>
            <strong>2 S Hawk Mountain Trail</strong>
            A typical Goswick Ranch property view — open sky, native Arizona scrub, and the Bradshaw Mountain
            foothills. Elevations on the ranch range from 4,400 to 6,000 feet, yielding dramatic panoramas year-round.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1062124_P57.jpg`}
               alt="Panoramic view from a high Goswick Ranch ridgeline — rock and scrub foreground, sweeping valley vista below"
               loading="lazy">
          <figcaption>
            <strong>Ridgeline Panorama</strong>
            View from the upper elevation of the ranch. The valley floor — including Mayer, Big Bug Creek,
            and the Agua Fria basin — lies well below the community's 4,400–6,000 ft elevation range.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1048555_P10.jpg`}
               alt="Wide valley panorama from high elevation at Goswick Ranch — Mayer and Big Bug Creek corridor visible in the valley below"
               loading="lazy">
          <figcaption>
            <strong>Big Bug Creek Valley</strong>
            The Mayer townsite and Big Bug Creek corridor seen far below from a Goswick Ranch ridgeline.
            The community sits 300–1,500 feet above the valley floor.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1048555_P04.jpg`}
               alt="Rocky Precambrian granite outcrop at a canyon-edge vantage point on Goswick Ranch — deep valley visible below"
               loading="lazy">
          <figcaption>
            <strong>Granite Outcrop — Canyon Edge</strong>
            The Bradshaw Mountains are underlain by Precambrian granite more than 1.7 billion years old —
            among the oldest exposed rock in Arizona.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1065556_P09.jpg`}
               alt="Large Precambrian granite and schist boulder with high desert scrub and Bradshaw mountain ridgelines behind"
               loading="lazy">
          <figcaption>
            <strong>Bradshaw Granite</strong>
            Ancient Precambrian granite boulders are a defining feature of the Goswick Ranch terrain —
            visible from throughout the community and from the valley below.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1062124_P36.jpg`}
               alt="Aerial drone view of a completed home sited at the crest of a Goswick Ranch ridgeline with a winding dirt driveway and chaparral vegetation"
               loading="lazy">
          <figcaption>
            <strong>Ridgeline Home — Aerial</strong>
            A completed home on a Goswick Ranch ridgeline with 360-degree exposure. The private winding
            driveway and 9-acre minimum lots create genuine separation between homes.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1062124_P38.jpg`}
               alt="Wide aerial drone view of a Goswick Ranch ridgeline home showing the Mayer townsite and Big Bug Creek valley far below"
               loading="lazy">
          <figcaption>
            <strong>Ridgeline Home — Wide Aerial</strong>
            The Mayer townsite and Big Bug Creek valley far below — the private road network and
            topographic isolation from the valley are visible in context.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1079880_P06.jpg`}
               alt="Aerial view of a densely forested upper-elevation Goswick Ranch parcel with oak and juniper canopy, a winding private road, and small outbuildings"
               loading="lazy">
          <figcaption>
            <strong>Upper-Elevation Forested Parcel</strong>
            A higher-elevation parcel (approaching 6,000 ft) showing the dense live oak and juniper canopy —
            a forested character that surprises many visitors expecting low desert.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1065556_P22.jpg`}
               alt="Dirt road descending toward the Big Bug Creek valley from Goswick Ranch, summer haze visible in the valley"
               loading="lazy">
          <figcaption>
            <strong>Private Road to the Valley</strong>
            A private ranch road descending toward Big Bug Creek. Poland Road begins at AZ-69 and
            climbs approximately 5.9 miles through the Bradshaws to Five Corners at 6,926 ft.
          </figcaption>
        </figure>
      </div>

    </div>

    <!-- Four Seasons -->
    <h2 class="gallery-section-title">Four Seasons</h2>
    <div class="photo-grid">

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1069387_P00.jpg`}
               alt="Spring wildflowers — brittlebush blanketing a Goswick Ranch meadow with Bradshaw peaks visible behind"
               loading="lazy">
          <figcaption>
            <strong>Spring — Wildflower Bloom</strong>
            Brittlebush covers the meadows in spring yellow. The Bradshaw wildflower season peaks April–May —
            lupine, penstemon, globe mallow, and owl's clover across the hillsides.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1069387_P16.jpg`}
               alt="Yellow brittlebush wildflowers scattered across Goswick Ranch scrubland with prickly pear cactus in spring"
               loading="lazy">
          <figcaption>
            <strong>Spring — Brittlebush &amp; Cactus</strong>
            The chaparral zone in spring: brittlebush in bloom, prickly pear, and native scrub.
            The 2025–2026 season saw wildflowers as early as January — the earliest in 15 years.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1069387_P13.jpg`}
               alt="Lush green monsoon-season hillsides at Goswick Ranch with directional sunlight and dramatic cloud formations"
               loading="lazy">
          <figcaption>
            <strong>Summer — Monsoon Green</strong>
            The Arizona monsoon transforms the Bradshaw foothills to vivid green. Monsoonal moisture
            typically first arrives in early July; afternoon thunderstorms build 2:00–4:00 PM.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1069387_P02.jpg`}
               alt="Bradshaw mountain ridgelines at Goswick Ranch under dramatic monsoon storm clouds"
               loading="lazy">
          <figcaption>
            <strong>Summer — Monsoon Storm</strong>
            Monsoon clouds build over the Bradshaws. Arizona sees over 500,000 lightning strikes per
            monsoon season; storm-watching from a high vantage is one of summer's pleasures here.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1069387_P23.jpg`}
               alt="Dramatic monsoon thunderhead at golden sunset over the Goswick Ranch area — golden glowing cumulus and green hills below"
               loading="lazy">
          <figcaption>
            <strong>Summer — Monsoon Sunset</strong>
            A classic Bradshaw Mountains monsoon thunderhead at golden hour. The combination of
            elevation and valley views makes weather photography exceptional here.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1069387_P09.jpg`}
               alt="Rainbow arching over the Mayer and Big Bug Creek valley as seen from Goswick Ranch, prickly pear cactus in the foreground"
               loading="lazy">
          <figcaption>
            <strong>Summer/Fall — Valley Rainbow</strong>
            Rainbow over the Mayer and Big Bug Creek valley. Post-monsoon clearing produces vivid
            rainbow conditions against the valley floor far below.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1069387_P33.jpg`}
               alt="Rainbow over green Bradshaw mountain ridges at Goswick Ranch in golden evening light"
               loading="lazy">
          <figcaption>
            <strong>Summer/Fall — Mountain Rainbow</strong>
            Evening light and post-monsoon moisture produce vivid rainbow conditions over the
            Bradshaw ridgelines.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1069387_P05.jpg`}
               alt="Golden cottonwood tree in peak fall color at Goswick Ranch with Bradshaw mountain peaks visible behind"
               loading="lazy">
          <figcaption>
            <strong>Fall — Peak Color</strong>
            A cottonwood in peak fall gold. The Senator Highway south toward Crown King is one of
            Arizona's premier fall-color drives, accessible within 20 minutes of the gate.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1069387_P19.jpg`}
               alt="Winter sunset over snow-capped Bradshaw peaks as seen from a Goswick Ranch home — orange and crimson sky"
               loading="lazy">
          <figcaption>
            <strong>Winter — Snow-Capped Peaks at Sunset</strong>
            Winter sunsets over snow-capped Bradshaw peaks. Light snow falls ~16 days per year and
            typically melts within a day or two at community elevation.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1069387_P29.jpg`}
               alt="Prickly pear cactus covered in snow at Goswick Ranch with snow-capped peaks and a cloud inversion layer behind"
               loading="lazy">
          <figcaption>
            <strong>Winter — Cactus in Snow</strong>
            One of Arizona's most distinctive images: prickly pear dusted with snow, Bradshaw peaks behind,
            cloud inversion layer filling the valley below. Bortle Class 3–4 skies make winter the best
            stargazing season.
          </figcaption>
        </figure>
      </div>

    </div>

    <!-- Big Bug Creek & Ranch Life -->
    <h2 class="gallery-section-title">Big Bug Creek &amp; Ranch Life</h2>
    <div class="photo-grid">

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/chk1058583_P30.jpg`}
               alt="Big Bug Creek flowing over flat sandstone rocks with cottonwood and riparian vegetation lining the canyon banks"
               loading="lazy">
          <figcaption>
            <strong>Big Bug Creek — Flowing Water</strong>
            Big Bug Creek flows through a canyon below the ranch — flat sandstone rock formations,
            clear water in season, and cottonwood-lined banks visible from Poland Road.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1069387_P32.jpg`}
               alt="Three black Angus cattle grazing in chaparral scrub on the Goswick Ranch area"
               loading="lazy">
          <figcaption>
            <strong>Open Range Cattle</strong>
            Black Angus cattle in the Goswick Ranch area. Yavapai County is open range: property
            owners are responsible for fencing livestock <em>out</em>. Mark Goswick Cattle Co.
            operates active ranching nearby.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/chk1058583_P45.jpg`}
               alt="Flat grassy area with mature juniper trees and a historic dry-stone retaining wall, green Bradshaw hills behind"
               loading="lazy">
          <figcaption>
            <strong>Historic Stone Wall</strong>
            A dry-stone retaining wall consistent with late 19th / early 20th century ranch construction —
            likely from the original Goswick Ranch homestead. The family has been part of this
            landscape since the 1860s.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <img src={`${base}/img/1065556_P19.jpg`}
               alt="Aerial view showing a disturbed hillside with road cuts consistent with mine tailings or reclamation in the Big Bug Mining District"
               loading="lazy">
          <figcaption>
            <strong>Big Bug Mining District</strong>
            Aerial view of historic mining activity in the Big Bug District — 627,000+ oz gold,
            1867–1959. The Henrietta Mine lies within or adjacent to the subdivision; well water
            should be tested for arsenic every 5 years.
          </figcaption>
        </figure>
      </div>

    </div>

    <!-- Aerial & Mapping -->
    <h2 class="gallery-section-title">Aerial &amp; Mapping</h2>
    <div class="photo-grid">

      <div class="photo-item">
        <figure>
          <a href={`${base}/img/aerial-value-overlay.png`} target="_blank" rel="noopener">
            <img src={`${base}/img/aerial-value-overlay.png`}
                 alt="Google Earth aerial of Goswick Ranch with MLS price overlays: lots $250K–$599K, surrounding parcels $43K–$220K"
                 loading="lazy">
          </a>
          <figcaption>
            <strong>Aerial Overview with Property Values</strong>
            Goswick Ranch lots ($250K–$599K) vs. neighboring unimproved parcels ($43K–$220K).
            The ~57% five-year appreciation reflects the gated-access and covenant premium.
          </figcaption>
        </figure>
      </div>

      <div class="photo-item">
        <figure>
          <a href={`${base}/img/parcel-map.png`} target="_blank" rel="noopener">
            <img src={`${base}/img/parcel-map.png`}
                 alt="Yavapai County GIS parcel map of Goswick Ranch showing approximately 25–35 irregular lots and the private road network"
                 loading="lazy">
          </a>
          <figcaption>
            <strong>Yavapai County GIS Parcel Map</strong>
            Official GIS parcel map — ~25–35 lots, Plat Book 56 Pages 8–12. Irregular lot shapes
            reflect the rugged Bradshaw Mountain terrain.
          </figcaption>
        </figure>
      </div>

    </div>

    <!-- Subdivision Plat -->
    <h2 class="gallery-section-title">Subdivision Plat</h2>
    <div class="photo-grid">

      <div class="photo-item wide">
        <figure>
          <a href={`${base}/docs/survey.pdf`} target="_blank" rel="noopener">
            <img src={`${base}/img/survey-map.png`}
                 alt="Results of Survey — Goswick Ranch, 850.63 acres, Sections 31 and 32, T 13 N, R 1 E, Yavapai County, Arizona"
                 loading="lazy">
          </a>
          <figcaption>
            <strong>Official Subdivision Plat (850.63 acres)</strong>
            Recorded survey plat — Sections 31 &amp; 32, T 13 N, R 1 E, Yavapai County.
            <a href={`${base}/docs/survey.pdf`} target="_blank" rel="noopener">Download full survey PDF &rarr;</a>
          </figcaption>
        </figure>
      </div>

    </div>

    <div class="prose" style="margin-top: var(--space-12); padding-top: var(--space-8); border-top: 1px solid var(--color-border);">
      <h2>Share Your Photos</h2>
      <p>Community members are invited to contribute photos of the ranch, gate entrance, mountain views, Big Bug Creek overlook, wildlife, and seasonal scenery. Photos will be added to this gallery with your permission.</p>
      <p><a href={`${base}/contact/`} class="btn-secondary">Contact the board to submit photos &rarr;</a></p>
    </div>

  </div>
</PageLayout>
