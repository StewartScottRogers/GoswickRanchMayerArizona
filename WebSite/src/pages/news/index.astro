---
import PageLayout from '../../layouts/PageLayout.astro';

const base = '/GoswickRanchMayerArizona';
---

<PageLayout
  title="News & Updates — Goswick Ranch HOA"
  description="Community news and updates from the Goswick Ranch HOA."
  pageTitle="News & Updates"
  breadcrumbs={[
    { label: 'Home', href: `${base}/` },
    { label: 'News & Updates' }
  ]}
>
  <div class="page-content">
    <div class="notice notice-info">
      <p><strong>Coming soon.</strong> Community news and announcements are pending board submission. <a href={`${base}/contact/`}>Contact the board</a> with questions.</p>
    </div>
  </div>
</PageLayout>
