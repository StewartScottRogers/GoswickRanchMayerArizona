---
import PageLayout from '../../layouts/PageLayout.astro';

const base = '/GoswickRanchMayerArizona';
---

<PageLayout
  title="Contact the Board — Goswick Ranch HOA"
  description="Contact the Goswick Ranch HOA Board of Directors."
  pageTitle="Contact the Board"
  breadcrumbs={[
    { label: 'Home', href: `${base}/` },
    { label: 'Contact' }
  ]}
>
  <div class="page-content">

    <div class="notice notice-warn" style="margin-bottom: var(--space-8);">
      <p>For <strong>urgent matters or emergencies</strong>, call <strong>911</strong> or the Yavapai County Sheriff non-emergency line at <a href="tel:+19287713260">(928) 771-3260</a>. Do not use this form for emergencies.</p>
    </div>

    <div class="two-col">

      <div>
        <p style="margin-bottom: var(--space-6); color: var(--color-text-muted);">Use the form below to reach the Goswick Ranch HOA Board of Directors. We typically respond within a few business days.</p>

        <div class="notice notice-warn" style="margin-bottom: var(--space-6);">
          <p><strong>Form setup pending:</strong> This form requires a Formspree account ID before it can deliver messages. Until configured, the Submit button will not work. The board will activate this form soon.</p>
        </div>
        <!-- Replace YOUR_FORM_ID with a real Formspree form ID from formspree.io -->
        <form class="form-container" action="https://formspree.io/f/YOUR_FORM_ID" method="POST" novalidate>

          <div class="form-group">
            <label for="name">Name <span aria-hidden="true">*</span></label>
            <input type="text" id="name" name="name" required autocomplete="name" placeholder="Your full name">
          </div>

          <div class="form-group">
            <label for="email">Email <span aria-hidden="true">*</span></label>
            <input type="email" id="email" name="email" required autocomplete="email" placeholder="your@email.com">
          </div>

          <div class="form-group">
            <label for="phone">Phone <span class="optional-label">(optional)</span></label>
            <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="(928) 555-0100">
          </div>

          <div class="form-group">
            <label for="subject">Subject <span aria-hidden="true">*</span></label>
            <select id="subject" name="subject" required>
              <option value="" disabled selected>Select a subject…</option>
              <option value="General Question">General Question</option>
              <option value="Dues Inquiry">Dues Inquiry</option>
              <option value="Rule Concern">Rule Concern</option>
              <option value="ARC Request">Architectural Review Request</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Message <span aria-hidden="true">*</span></label>
            <textarea id="message" name="message" required placeholder="Describe your question or concern…"></textarea>
          </div>

          <button type="submit" class="btn-primary">Send Message</button>

          <p class="form-note" style="margin-top: var(--space-4);">
            For architectural review requests, you may also use the dedicated <a href={`${base}/contact/arc/`}>ARC Request form</a>.
          </p>

        </form>
      </div>

      <div>
        <h2 style="font-size: var(--text-2xl); margin-bottom: var(--space-4);">Other Ways to Reach Us</h2>
        <p style="color: var(--color-text-muted); margin-bottom: var(--space-6);">Mailing address will be posted here once confirmed by the board. A PO Box is recommended — do not use personal home addresses.</p>

        <div class="notice">
          <p><strong>Board mailing address:</strong> Pending — check back soon.</p>
        </div>

        <div style="margin-top: var(--space-6);">
          <h3 style="font-size: var(--text-xl); margin-bottom: var(--space-4);">ARC Requests</h3>
          <p style="color: var(--color-text-muted); margin-bottom: var(--space-4);">Planning an exterior improvement or new structure? Submit a dedicated request.</p>
          <a href={`${base}/contact/arc/`} class="btn-secondary">ARC Request Form &rarr;</a>
        </div>
      </div>

    </div>

  </div>
</PageLayout>
