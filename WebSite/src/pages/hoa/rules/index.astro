---
import PageLayout from '../../../layouts/PageLayout.astro';

const base = '/GoswickRanchMayerArizona';
---

<PageLayout
  title="Rules & Regulations — Goswick Ranch HOA"
  description="Community rules and regulations for Goswick Ranch HOA."
  pageTitle="Rules & Regulations"
  pageSubtitle="Community rules covering property use, construction, and day-to-day standards."
  breadcrumbs={[
    { label: 'Home', href: `${base}/` },
    { label: 'HOA Info', href: `${base}/hoa/` },
    { label: 'Rules & Regulations' }
  ]}
>
  <div class="page-content">
    <div class="notice notice-info">
      <p><strong>Coming soon.</strong> The full rules and regulations document is pending board review and submission. <a href={`${base}/contact/`}>Contact the board</a> with questions.</p>
    </div>
    <div class="prose" style="margin-top: var(--space-8);">
      <p>In the meantime, the key provisions of the CC&Rs are summarized on the <a href={`${base}/buyers/`}>For Buyers</a> page, and the full CC&Rs are available for download on the <a href={`${base}/hoa/documents/`}>Governing Documents</a> page.</p>
    </div>
  </div>
</PageLayout>
