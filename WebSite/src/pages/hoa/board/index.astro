---
import PageLayout from '../../../layouts/PageLayout.astro';

const base = '/GoswickRanchMayerArizona';
---

<PageLayout
  title="Board of Directors — Goswick Ranch HOA"
  description="Meet the Goswick Ranch HOA Board of Directors."
  pageTitle="Board of Directors"
  pageSubtitle="The volunteer board that governs the Goswick Ranch HOA."
  breadcrumbs={[
    { label: 'Home', href: `${base}/` },
    { label: 'HOA Info', href: `${base}/hoa/` },
    { label: 'Board of Directors' }
  ]}
>
  <div class="page-content">
    <div class="notice notice-info">
      <p><strong>Coming soon.</strong> Board member information is pending submission. <a href={`${base}/contact/`}>Contact the board</a> with questions.</p>
    </div>
  </div>
</PageLayout>
