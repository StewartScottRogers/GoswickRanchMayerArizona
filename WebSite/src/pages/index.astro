---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = '/GoswickRanchMayerArizona';
---

<BaseLayout
  title="Goswick Ranch HOA — Mayer, Arizona"
  description="Goswick Ranch is a private gated ranch community in the Bradshaw Mountains near Mayer, Arizona. Official HOA website."
>
  <main id="main">

    <!-- Hero -->
    <section class="hero" aria-label="Community welcome">
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <h1>Goswick Ranch</h1>
        <p class="hero-tagline">A Private Ranch Community in the Bradshaw Mountains · Mayer, Arizona</p>
        <div style="display:flex; gap: var(--space-4); flex-wrap: wrap; justify-content: center; margin-top: var(--space-6);">
          <a href={`${base}/hoa/`} class="btn-outline">I'm a Resident</a>
          <a href={`${base}/buyers/`} class="btn-primary">Thinking of Buying Here?</a>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="stats-bar" aria-label="Community facts at a glance">
      <div class="stat-item">
        <span class="stat-value">$216/yr</span>
        <span class="stat-label">HOA annual assessment</span>
      </div>
      <div class="stat-item">
        <span class="stat-value">9 acres</span>
        <span class="stat-label">Minimum lot size</span>
      </div>
      <div class="stat-item">
        <span class="stat-value">57%</span>
        <span class="stat-label">5-yr appreciation (2020–2026)</span>
      </div>
      <div class="stat-item">
        <span class="stat-value">~$476/yr</span>
        <span class="stat-label">Median property tax (Mayer ZIP)</span>
      </div>
      <div class="stat-item">
        <span class="stat-value">4,400–6,000 ft</span>
        <span class="stat-label">Elevation range</span>
      </div>
      <div class="stat-item">
        <span class="stat-value">27 miles</span>
        <span class="stat-label">To downtown Prescott</span>
      </div>
    </section>
    <p class="stats-source">HOA fee from MLS disclosures; appreciation estimate Yavapai County 2020–2026; property taxes per county assessor.</p>

    <!-- Welcome + Dual CTA -->
    <section class="section">
      <div class="page-content">
        <div class="prose">
          <p>Goswick Ranch is a small, exclusive gated community nestled in the foothills of the Bradshaw Mountains near Mayer, Arizona. Set at elevations ranging from 4,400 to 6,000 feet, the community overlooks Big Bug Creek and offers sweeping views of one of central Arizona's most dramatic mountain ranges.</p>
          <p>With minimum 9-acre lots and site-built homes only, Goswick Ranch preserves the open, rural character that makes this corner of Yavapai County special — a true Arizona ranch lifestyle within reach of both Prescott and the Phoenix metro area.</p>
        </div>

        <!-- Dual Audience Cards -->
        <div class="audience-cards">
          <div class="audience-card">
            <h2>I'm a Resident</h2>
            <p>Find HOA documents, governing rules, board information, emergency contacts, utility providers, and community resources.</p>
            <ul>
              <li><a href={`${base}/hoa/documents/`}>HOA Documents</a></li>
              <li><a href={`${base}/resources/emergency/`}>Emergency Info</a></li>
              <li><a href={`${base}/resources/utilities/`}>Utilities</a></li>
              <li><a href={`${base}/contact/`}>Contact the Board</a></li>
            </ul>
            <a href={`${base}/hoa/`} class="btn-secondary">Go to HOA Info &rarr;</a>
          </div>
          <div class="audience-card">
            <h2>Thinking of Buying Here?</h2>
            <p>Explore the lifestyle, understand the numbers, and get the information you need — whether you're a local agent or relocating from out of state.</p>
            <ul>
              <li><a href={`${base}/lifestyle/`}>Life Here — seasons, dark skies, recreation</a></li>
              <li><a href={`${base}/buyers/`}>Financial advantages &amp; CC&amp;R summary</a></li>
              <li><a href={`${base}/buyers/faq/`}>Buyer FAQ</a></li>
            </ul>
            <a href={`${base}/buyers/`} class="btn-primary">For Buyers &rarr;</a>
          </div>
        </div>

        <!-- Community Map -->
        <figure class="survey-map" style="margin-top: var(--space-12);">
          <a href={`${base}/docs/survey.pdf`} target="_blank" rel="noopener" aria-label="View full survey PDF">
            <img src={`${base}/img/survey-map.png`}
                 alt="Results of Survey — Goswick Ranch, a portion of Sections 31 and 32, T 13 N, R 1 E, Yavapai County, Arizona. 850.63 acres. Shows individual numbered lots, easements, and a vicinity map."
                 width="1545" height="912"
                 loading="lazy"
                 style="width:100%; height:auto; border:1px solid var(--color-border); border-radius:4px;">
          </a>
          <figcaption style="margin-top: var(--space-2); font-size: var(--text-sm); color: var(--color-text-muted);">
            Goswick Ranch subdivision plat &mdash; 850.63 acres, Sections 31 &amp; 32, T 13 N, R 1 E, Yavapai County.
            <a href={`${base}/docs/survey.pdf`} target="_blank" rel="noopener">Download full survey (PDF)</a>
          </figcaption>
        </figure>

        <!-- Quick Links -->
        <h2 class="section-title" style="margin-top: var(--space-12);">Quick Links</h2>
        <div class="card-grid">
          <a class="card" href={`${base}/hoa/documents/`}>
            <h3>HOA Documents</h3>
            <p>CC&amp;Rs, bylaws, survey plat, and governing documents.</p>
            <span class="card-cta">View documents &rarr;</span>
          </a>
          <a class="card" href={`${base}/resources/emergency/`}>
            <h3>Emergency Services</h3>
            <p>Sheriff, fire district, wildfire alerts, evacuation zones, and emergency contacts.</p>
            <span class="card-cta">View numbers &rarr;</span>
          </a>
          <a class="card" href={`${base}/lifestyle/`}>
            <h3>Life Here</h3>
            <p>Seasons, dark skies, wildlife, recreation, and nearby destinations within 60 miles.</p>
            <span class="card-cta">Explore the area &rarr;</span>
          </a>
          <a class="card" href={`${base}/contact/`}>
            <h3>Contact the Board</h3>
            <p>Questions, concerns, or architectural review requests for the HOA board.</p>
            <span class="card-cta">Get in touch &rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Community Snapshot -->
    <section class="snapshot-strip" aria-label="Community facts">
      <dl class="snapshot-grid">
        <div class="snapshot-item">
          <dt>Location</dt>
          <dd>Mayer, AZ 86333 · Yavapai County</dd>
        </div>
        <div class="snapshot-item">
          <dt>Setting</dt>
          <dd>Bradshaw Mountain foothills · Big Bug Creek overlook</dd>
        </div>
        <div class="snapshot-item">
          <dt>Elevation</dt>
          <dd>~4,400–6,000 ft</dd>
        </div>
        <div class="snapshot-item">
          <dt>Access</dt>
          <dd>Gated · S Goswick Ranch Rd</dd>
        </div>
        <div class="snapshot-item">
          <dt>Lot minimum</dt>
          <dd>9 acres</dd>
        </div>
        <div class="snapshot-item">
          <dt>Home minimum</dt>
          <dd>1,500 sq ft · site-built only</dd>
        </div>
        <div class="snapshot-item">
          <dt>HOA assessment</dt>
          <dd>$216 / year</dd>
        </div>
        <div class="snapshot-item">
          <dt>Zoning</dt>
          <dd>RCU-2A (Yavapai County)</dd>
        </div>
        <div class="snapshot-item">
          <dt>Night skies</dt>
          <dd>Bortle Class 3 — brilliant Milky Way</dd>
        </div>
      </dl>
    </section>

  </main>
</BaseLayout>
